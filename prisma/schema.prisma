generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Recruit {
  id        String         @id // 4-digit string e.g. "1203"
  platoon   Int
  section   Int
  bed       Int
  createdAt DateTime       @default(now())
  statuses  StatusRecord[]
}

enum StatusType {
  MC
  LD
  EX
  EX_STAY_IN
  SEND_OUT_URGENT
  SEND_OUT_NON_URGENT
  REPORTING_SICK
  OTHERS
}

model StatusRecord {
  id         String     @id @default(uuid())
  recruitId  String
  type       StatusType
  startDate  DateTime
  endDate    DateTime
  remark     String     @default("")
  outOfCamp  Boolean    @default(false)
  createdAt  DateTime   @default(now())

  recruit Recruit @relation(fields: [recruitId], references: [id], onDelete: Cascade)

  @@index([recruitId])
  @@index([startDate, endDate])
}
